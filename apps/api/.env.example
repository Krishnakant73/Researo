# Researo API Environment
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS: comma-separated list of allowed web origins.
# In production set this to your deployed web URL, e.g.
#   CORS_ORIGINS=https://researo-web.up.railway.app
# Use "*" to allow any origin (credentials are disabled automatically).
CORS_ORIGINS=http://localhost:3000

# Database
# - Local/dev (SQLite):   sqlite+aiosqlite:///./data/researo.db
# - Production (Postgres): paste Railway's DATABASE_URL. postgres:// and
#   postgresql:// URLs are auto-upgraded to the async asyncpg driver.
DATABASE_URL=sqlite+aiosqlite:///./data/researo.db

# Vector store (pluggable behind the VectorStore interface)
# VECTOR_BACKEND=chroma is the production default; the app auto-falls back to
# the dependency-free "numpy" store if chromadb can't be imported (e.g. Windows
# without MSVC build tools). Set VECTOR_BACKEND=numpy to force the fallback.
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION=researo_chunks

# Reranker (pluggable). Swap for BAAI/bge-reranker-v2-m3 if you want the larger
# cross-encoder. RERANKER_BACKEND=none disables it (heuristic rerank is used).
RERANKER_BACKEND=cross-encoder
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# LLM Gateway (OpenRouter). Leave OPENROUTER_API_KEY blank to run in the
# offline deterministic fallback; set it to route agents to live models.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o-mini
FAST_MODEL=openai/gpt-4o-mini
QUALITY_MODEL=openai/gpt-4o

# Embeddings (pluggable behind the EmbeddingProvider interface)
# EMBEDDING_PROVIDER=bge uses local sentence-transformers; "hash" is a
# dependency-free fallback. Set EMBEDDING_MODEL=BAAI/bge-m3 for the larger model
# (note: 1024-dim, ~2GB — re-index required after changing the model).
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
USE_LOCAL_EMBEDDINGS=true

# Retrieval
TOP_K_DENSE=12
TOP_K_BM25=12
TOP_K_FINAL=8

# -----------------------------------------------------------------------
# Railway production example (mount a volume at /data on the API service):
#   APP_ENV=production
#   CORS_ORIGINS=https://<your-web>.up.railway.app
#   DATABASE_URL=sqlite+aiosqlite:////data/researo.db   # or Railway Postgres URL
#   CHROMA_PERSIST_DIR=/data/chroma_store
#   UPLOAD_DIR=/data/uploads
#   OPENROUTER_API_KEY=sk-or-...
# -----------------------------------------------------------------------
