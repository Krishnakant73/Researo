# Researo API Environment
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database (SQLite for prototype)
DATABASE_URL=sqlite+aiosqlite:///./data/researo.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION=researo_chunks

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# LLM Gateway
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o-mini
FAST_MODEL=openai/gpt-4o-mini
QUALITY_MODEL=openai/gpt-4o

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
USE_LOCAL_EMBEDDINGS=true

# Retrieval
TOP_K_DENSE=12
TOP_K_BM25=12
TOP_K_FINAL=8
