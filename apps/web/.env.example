# Researo web environment
#
# Base URL of the Researo API. This is baked into the client bundle at build
# time, so on Railway set it as a BUILD variable on the web service, pointing
# at your deployed API's public URL, e.g.:
#   NEXT_PUBLIC_API_URL=https://researo-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
